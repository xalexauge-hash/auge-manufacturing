<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if seo.title %}{{ seo.title }}{% else %}{{ title }} | {{ company.name }}{% endif %}</title>
    <meta name="description" content="{% if seo.description %}{{ seo.description }}{% else %}{{ company.description }}{% endif %}">
    <link rel="canonical" href="{{ site.url }}{{ page.url | replace('//', '/') }}">
    {% if seo.noindex %}
    <meta name="robots" content="noindex, nofollow">
    {% else %}
    <meta name="robots" content="index, follow">
    {% endif %}
    <!-- Open Graph -->
    <meta property="og:title" content="{% if seo.title %}{{ seo.title }}{% else %}{{ title }} | {{ company.name }}{% endif %}">
    <meta property="og:description" content="{% if seo.description %}{{ seo.description }}{% else %}{{ company.description }}{% endif %}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url | replace('//', '/') }}">
    <meta property="og:image" content="{% if seo.image %}{{ site.url }}{{ seo.image }}{% else %}{{ site.url }}/public/images/og-default.svg{% endif %}">
    <!-- TODO: Ersetzen durch echtes OG-Bild, z.B. og-default.jpg -->
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% if seo.title %}{{ seo.title }}{% else %}{{ title }} | {{ company.name }}{% endif %}">
    <meta name="twitter:description" content="{% if seo.description %}{{ seo.description }}{% else %}{{ company.description }}{% endif %}">
    <meta name="twitter:image" content="{% if seo.image %}{{ site.url }}{{ seo.image }}{% else %}{{ site.url }}/public/images/og-default.svg{% endif %}">
    <!-- TODO: Ersetzen durch echtes OG-Bild -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "{{ company.name }}",
      "url": "{{ site.url }}",
    "logo": "{{ site.url }}/public/auge_manufacturing_logo.png",
    "email": "{{ company.email }}",
    "telephone": "{{ company.phone }}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{{ company.street }}",
        "postalCode": "{{ company.postalCode }}",
        "addressLocality": "{{ company.city }}",
        "addressCountry": "{{ company.country }}"
      },
            "description": "{{ company.description }}",
            "areaServed": ["Riedering","Rosenheim","Chiemgau","Oberbayern","München"]
    }
    </script>
    <link rel="stylesheet" href="/public/style.css">
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="48x48" href="/public/images/fav_ico.png">
    <link rel="shortcut icon" href="/public/images/fav_ico.png">
    <style>
        /* Minimaler Zusatz, um das Bild einzupassen */
        .logo img {
            height: 200px;
            width: auto;
            vertical-align: middle;
        }
        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>

    <header>
        <div class="logo">
            <a href="/">
                <img src="/public/auge_manufacturing_logo.png" alt="AUGÉ MANUFACTURING">
            </a>
        </div>
    </header>

    <nav>
        <div class="menu-toggle" onclick="toggleMenu()">☰ Menü</div>
        <div class="nav-links" id="navLinks">
            <a href="/" class="{% if page.url == '/' %}active{% endif %}">
                Home
            </a>
            <a href="/ueber-uns/" class="{% if page.url == '/ueber-uns/' %}active{% endif %}">
                Über mich
            </a>
            <a href="/leistungen/" class="{% if page.url == '/leistungen/' %}active{% endif %}">
                Leistungen
            </a>
            <a href="/maschinenpark/" class="{% if page.url == '/maschinenpark/' %}active{% endif %}">
                Maschinenpark
            </a>
            <a href="/kontakt/" class="{% if page.url == '/kontakt/' %}active{% endif %}">
                Kontakt
            </a>
        </div>
    </nav>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <div class="footer-content">
            <div class="footer-section">
                <h4>Kontakt Info</h4>
                <p><strong>Adresse:</strong> {{ company.contact.address }}</p>
                <p><strong>Telefon:</strong> <a href="tel:{{ company.contact.phone }}">{{ company.contact.phone }}</a></p>
                <p><strong>E-Mail:</strong> <a href="mailto:{{ company.contact.email }}">{{ company.contact.email }}</a></p>
            </div>
            
            <div class="footer-section">
                <h4>Rechtliches</h4>
                <ul style="list-style: none; padding: 0;">
                    <li><a href="/impressum/" style="color: inherit; text-decoration: none;">Impressum</a></li>
                    <li><a href="/datenschutz/" style="color: inherit; text-decoration: none;">Datenschutzerklärung</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <p style="margin: 0;">© 2026 Alexander Augé, M.Sc.</p>
            </div>
        </div>
    </footer>
    </footer>

    <script>
        function toggleMenu() {
            var x = document.getElementById("navLinks");
            if (x.className === "nav-links") {
                x.className += " show";
            } else {
                x.className = "nav-links";
            }
        }
    </script>

</body>
</html>
